{
  "name": "blog-admin",
  "version": "1.0.0",
  "description": "Blog management system with MongoDB and React",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:install": "cd client && npm install",
    "build": "npm run client:build",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && npm run client:install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "blog",
    "admin",
    "mongodb",
    "express",
    "react",
    "authentication"
  ],
  "author": "Your Name",
  "license": "MIT"
}
